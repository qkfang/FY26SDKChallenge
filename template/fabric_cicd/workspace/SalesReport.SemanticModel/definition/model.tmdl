model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["SalesOrderHeader","SalesOrderDetail","Product","Customer","ProductCategory"]

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_ProTooling = ["DevMode"]

ref table SalesOrderHeader
ref table SalesOrderDetail
ref table Product
ref table Customer
ref table ProductCategory

ref expression DatabaseQuery

ref cultureInfo en-US
