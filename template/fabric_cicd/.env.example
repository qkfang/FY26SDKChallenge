# .env.example — Copy this file to .env and fill in your values.
# .env is excluded from source control via .gitignore.

# ── Service principal credentials ────────────────────────────────────────────
# Used by deploy.ps1 to authenticate the fabric-cicd Python deployer.
TENANTID=<your-entra-tenant-id>
CLIENTID=<your-service-principal-client-id>
CLIENTSECRET=<your-service-principal-client-secret>

# ── Fabric workspace service principal (deploy-cli.ps1) ──────────────────────
# Object ID and display name of the service principal to add as workspace Member.
# Defaults to the demo SP if not set.
SP_OBJECT_ID=<service-principal-object-id>
SP_DISPLAY_NAME=<service-principal-display-name>

# ── Optional: Fabric capacity admin override (deploy-bicep.ps1) ──────────────
# If not set, the currently signed-in Azure CLI user is used automatically.
# FABRIC_CAPACITY_ADMIN_ID=user@example.com

# ── Optional: SQL Server AAD admin override (deploy-bicep.ps1) ───────────────
# If not set, the currently signed-in Azure CLI user is used automatically.
# SQL_AAD_ADMIN_NAME=user@example.com
# SQL_AAD_ADMIN_OBJECT_ID=<aad-object-id>
